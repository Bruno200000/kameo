{
  "version": 2,
  "buildCommand": "node vercel-build.js",
  "outputDirectory": "frontend/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "methods": ["GET", "HEAD"],
      "dest": "/index.html"
    }
  ]
}
