{
  "version": 2,
  "buildCommand": "node vercel-build.js",
  "outputDirectory": "frontend/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "methods": ["GET", "HEAD"],
      "dest": "/index.html"
    }
  ]
}
